# Horizon API — set to your deployed backend (HTTPS, no trailing slash).
# Vercel: Project → Settings → Environment Variables → VITE_API_BASE_URL (Production + Preview).
# Example (Render):
VITE_API_BASE_URL=https://horizon-backend-4e0i.onrender.com
# Local dev:
# VITE_API_BASE_URL=http://127.0.0.1:3000

# Optional local-only (ignored when VITE_API_BASE_URL is set):
# VITE_API_HOST=127.0.0.1
# VITE_API_PORT=3000
